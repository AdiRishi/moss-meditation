{
  "name": "zen-meditation",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "pnpm --filter @repo/mobile start",
    "prebuild": "pnpm --filter @repo/mobile exec expo prebuild --clean",
    "android": "pnpm --filter @repo/mobile android",
    "ios": "pnpm --filter @repo/mobile ios",
    "lint": "pnpm --filter @repo/mobile lint",
    "test": "pnpm --filter @repo/mobile test",
    "typecheck": "pnpm --filter @repo/mobile typecheck",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "check": "pnpm run lint && pnpm run format:check && pnpm run typecheck"
  },
  "devDependencies": {
    "oxfmt": "^0.58.0"
  },
  "packageManager": "pnpm@11.10.0"
}
