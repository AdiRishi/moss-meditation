{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc", "import", "node"],
  "categories": {
    "correctness": "error"
  },
  "options": {
    "typeAware": true
  },
  "env": {
    "builtin": true,
    "node": true,
    "vitest": true
  },
  "ignorePatterns": [".output", ".turbo", "coverage", "dist", "node_modules"]
}
